---
const base = import.meta.env.BASE_URL;
---
<footer class="footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-title">Rastion</p>
      <p class="footer-copy">Executable TSP solvers, official suite results, and replayable TSPLIB runs.</p>
    </div>
    <div class="footer-links">
      <a href={`${base}arena/`}>Arena</a>
      <a href={`${base}solvers/`}>Solvers</a>
      <a href={`${base}about/`}>About</a>
      <a href={`${base}contribute/`}>Contribute</a>
    </div>
    <div class="footer-utility">
      <p>v0.1 covers three TSPLIB instances with versioned suite exports and arena replays.</p>
      <button class="toggle-theme" type="button" aria-label="Toggle color theme">Theme</button>
    </div>
  </div>
</footer>
