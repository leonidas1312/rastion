---
const base = import.meta.env.BASE_URL;
---
<footer class="footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-title">Rastion</p>
      <p class="footer-copy">Evaluation and publishing for executable routing solvers, with a TSP-first public release.</p>
    </div>
    <div class="footer-links">
      <a href={`${base}arena/`}>Arena</a>
      <a href={`${base}solvers/`}>Solvers</a>
      <a href={`${base}about/`}>About</a>
      <a href={`${base}contribute/`}>Contribute</a>
    </div>
    <div class="footer-utility">
      <p>v0.1 keeps the claim surface narrow: published adapters, generated result exports, and replayable TSPLIB runs.</p>
      <button class="toggle-theme" type="button" aria-label="Toggle color theme">Theme</button>
    </div>
  </div>
</footer>
