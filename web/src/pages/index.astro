---
import { existsSync, readFileSync } from "node:fs";

import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import { integrations } from "../data/integrations";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

function readJson(path, fallback) {
  return existsSync(path) ? JSON.parse(readFileSync(path, "utf-8")) : fallback;
}

const catalog = readJson(new URL("../../public/data/catalog.json", import.meta.url), { solvers: [], generated_at: null });
const leaderboards = readJson(new URL("../../public/data/leaderboards.json", import.meta.url), { leaderboards: [], generated_at: null });
const suites = readJson(new URL("../../public/data/suites.json", import.meta.url), { suites: [], generated_at: null });
const arena = readJson(new URL("../../public/data/tsp_arena.json", import.meta.url), { instances: [], generated_at: null });

const solverCount = Array.isArray(catalog.solvers) ? catalog.solvers.length : 0;
const leaderboardCount = Array.isArray(leaderboards.leaderboards) ? leaderboards.leaderboards.length : 0;
const suiteCount = Array.isArray(suites.suites) ? suites.suites.length : leaderboardCount;
const arenaCount = Array.isArray(arena.instances) ? arena.instances.length : 0;
const publishedCards = Array.isArray(catalog.solvers) ? catalog.solvers : [];
const publishedCardIds = new Set(publishedCards.map((row) => row.id));
const availableIntegrations = integrations.filter((item) => item.cardIds.some((id) => publishedCardIds.has(id)));
const latest = [catalog.generated_at, leaderboards.generated_at, suites.generated_at, arena.generated_at]
  .filter((value) => typeof value === "string" && value.length > 0)
  .sort()
  .reverse()[0];
const latestLabel = latest ? new Date(latest).toLocaleString() : "Awaiting export";
---
<BaseLayout title="Rastion • Executable Routing Solver Publishing" description="Rastion is the evaluation and publishing layer for executable routing solvers, with public TSP cards, replayable evidence, and artifact-backed comparisons." canonical="/" >
  <PageIntro
    eyebrow="Evaluation and publishing layer"
    title="Publish executable routing solvers with replayable evidence."
    lede="Rastion keeps the public release tight: published TSP adapters, reproducible result exports, and an Arena surface for replaying the exact runs behind the claims."
    split={true}
  >
    <div slot="actions" class="intro-actions">
      <a class="button-primary" href={`${base}arena/`}>Open the Arena</a>
      <a class="button-secondary" href={`${base}solvers/`}>Browse Solvers</a>
      <a class="text-link" href={`${base}about/#philosophy`}>Why this exists</a>
    </div>
    <div slot="note" class="note-cluster">
      <TrustNote href={`${base}about/#scope`} linkLabel="Current scope">
        v0.1 stays TSP-first on purpose. Public claims must be backed by generated exports, not a wrapper catalog.
      </TrustNote>
    </div>
    <aside slot="aside" class="proof-panel">
      <p class="kicker">Current public release</p>
      <div class="proof-grid">
        <div class="proof-item">
          <strong>{solverCount}</strong>
          <span>published adapter{solverCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{suiteCount}</strong>
          <span>evaluation suite{suiteCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{arenaCount}</strong>
          <span>arena replay{arenaCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{leaderboardCount}</strong>
          <span>published result export{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
      </div>
      <p class="proof-meta">Latest export: {latestLabel}</p>
    </aside>
  </PageIntro>

  <section class="section-block">
    <article class="section-panel integration-shell">
      <div class="section-heading section-heading-compact">
        <p class="kicker">Works with</p>
        <h2>Published integrations only</h2>
        <p>Every chip below maps to at least one real solver card in the repo. No aspirational ecosystem wall.</p>
      </div>
      <div class="integration-strip" aria-label="Published integrations">
        {availableIntegrations.map((item) => (
          <a class="integration-chip" href={item.href}>
            <img src={`${base}${item.logoPath}`} alt={item.label} />
            <span>{item.label}</span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="kicker">Product surface</p>
      <h2>Three ways to inspect the same evidence</h2>
      <p>Rastion is not a generic wrapper. It is one opinionated publication flow with three public surfaces around the same generated artifacts.</p>
    </div>
    <div class="destination-grid">
      <article class="destination-card">
        <p class="kicker">Arena</p>
        <h3>Replay the exported run</h3>
        <p>Inspect route geometry, trace progression, and BKS-relative performance for a single published instance at a time.</p>
        <div class="panel-meta">
          <span>{arenaCount} replay bundle{arenaCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}arena/`}>Open the arena</a>
      </article>
      <article class="destination-card">
        <p class="kicker">Solver cards</p>
        <h3>Inspect the published adapter</h3>
        <p>Check method, install path, dependency surface, limits, references, and current suite coverage before trusting a listing.</p>
        <div class="panel-meta">
          <span>{solverCount} solver card{solverCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}solvers/`}>Browse the catalog</a>
      </article>
      <article class="destination-card">
        <p class="kicker">Reproducible evals</p>
        <h3>Audit the publication contract</h3>
        <p>Trace every public claim back to the generated JSON, suite definitions, and repo flow that produced it.</p>
        <div class="panel-meta">
          <span>{suiteCount} suite definition{suiteCount === 1 ? "" : "s"}</span>
          <span>{leaderboardCount} result export{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}about/#evaluation`}>Read the contract</a>
      </article>
    </div>
  </section>

  <section class="section-block">
    <article class="section-panel quickstart-shell">
      <div class="section-heading">
        <p class="kicker">Quickstart</p>
        <h2>Shortest path from clone to visible evidence</h2>
        <p>Use the release smoke flow if you want the full repo-verified path. It installs dependencies, validates cards, regenerates public data, and builds the site.</p>
      </div>
      <div class="quickstart-grid">
        <div class="quickstart-card">
          <p class="kicker">One command</p>
          <pre><code>./scripts/release_smoke.sh</code></pre>
          <div class="panel-meta">
            <span>Installs full verification deps</span>
            <span>Runs tests and catalog validation</span>
            <span>Rebuilds public exports and Astro output</span>
          </div>
        </div>
        <div class="quickstart-card">
          <p class="kicker">Public artifacts</p>
          <div class="artifact-list">
            <code>web/public/data/catalog.json</code>
            <code>web/public/data/leaderboards.json</code>
            <code>web/public/data/tsp_arena.json</code>
          </div>
          <a class="text-link" href={`${base}contribute/`}>Open the contributor flow</a>
        </div>
      </div>
    </article>
  </section>

  <section class="section-block">
    <div class="vision-grid">
      <article class="section-panel">
        <div class="section-heading section-heading-compact">
          <p class="kicker">What Rastion is</p>
          <h2>An opinionated publication layer</h2>
        </div>
        <ul class="list-reset">
          <li>Executable adapters with visible install paths and failure modes.</li>
          <li>Artifact-backed comparisons tied to explicit suite definitions.</li>
          <li>A replay surface that lets readers inspect what was actually exported.</li>
        </ul>
      </article>
      <article class="section-panel">
        <div class="section-heading section-heading-compact">
          <p class="kicker">What Rastion is not</p>
          <h2>A generic solver wrapper marketplace</h2>
        </div>
        <ul class="list-reset">
          <li>Not a claim that one ranking spans unrelated routing families.</li>
          <li>Not a logo wall for integrations that have not shipped.</li>
          <li>Not a promise of VRP breadth before the public contract supports it.</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
