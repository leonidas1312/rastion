---
import { existsSync, readFileSync } from "node:fs";

import PageIntro from "../components/PageIntro.astro";
import SuitesTable from "../components/SuitesTable.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const catalogPath = new URL("../../public/data/catalog.json", import.meta.url);
const leaderboardsPath = new URL("../../public/data/leaderboards.json", import.meta.url);

const catalog = existsSync(catalogPath) ? JSON.parse(readFileSync(catalogPath, "utf-8")) : { solvers: [] };
const leaderboards = existsSync(leaderboardsPath) ? JSON.parse(readFileSync(leaderboardsPath, "utf-8")) : { leaderboards: [] };

const solverRows = Array.isArray(catalog.solvers) ? catalog.solvers : [];
const suiteRows = Array.isArray(leaderboards.leaderboards) ? leaderboards.leaderboards : [];
const solverCount = solverRows.length;
const suiteCount = suiteRows.length;
---
<BaseLayout title="Rastion • About" description="Method, scope, and export structure for Rastion's public TSP site." canonical="/about/">
  <PageIntro
    eyebrow="About"
    title="How the public TSP site is put together"
    lede="Rastion publishes one small TSP dataset across two public surfaces: solver cards and an Arena page that combines official results with replayable TSPLIB runs."
  >
    <TrustNote slot="note" href="#evaluation" linkLabel="Jump to evaluation details">
      The current public dataset contains {solverCount} solver cards and {suiteCount} official suite exports.
    </TrustNote>
  </PageIntro>

  <section class="section-block section-panel" id="positioning">
    <div class="section-heading">
      <p class="kicker">What ships</p>
      <h2>One dataset, two public surfaces</h2>
      <p>The site reads generated JSON from `web/public/data` and renders it as solver pages plus one Arena surface for replay and official results. The point is not to cover every routing problem; it is to make one TSP workflow legible end to end.</p>
    </div>
  </section>

  <section class="section-block" id="phase-1">
    <div class="section-heading">
      <p class="kicker">Public surface</p>
      <h2>What readers can inspect today</h2>
    </div>
    <div class="destination-grid">
      <article class="destination-card">
        <h3>Solvers</h3>
        <p>Executable TSP solver cards with installation, limits, references, and current suite coverage.</p>
      </article>
      <article class="destination-card">
        <h3>Arena</h3>
        <p>Replayable route geometry, best-distance-over-time traces, and official suite results for the exported TSPLIB runs.</p>
      </article>
      <article class="destination-card">
        <h3>Contributor flow</h3>
        <p>A repo-verified workflow for turning a local solver adapter into a published card and export set.</p>
      </article>
    </div>
  </section>

  <section class="section-block section-panel" id="limits">
    <div class="section-heading">
      <p class="kicker">Current scope</p>
      <h2>What is in bounds for v0.1</h2>
    </div>
    <ul class="list-reset">
      <li>Phase 1 is TSP only.</li>
      <li>Official results stay tied to the listed suites and instances.</li>
      <li>Broader routing variants stay out of the public contract until they have matching cards, evals, and replays.</li>
    </ul>
  </section>

  <section class="section-block section-panel" id="evaluation">
    <div class="section-heading">
      <p class="kicker">How evaluation works</p>
      <h2>Versioned suites with stored artifacts</h2>
      <p>Each official suite fixes its TSPLIB instance, iteration budget, time budget, and seed list. The generated JSON captures the per-instance result rows, aggregate standings, and the artifact path that produced the table.</p>
    </div>
    <ul class="list-reset">
      <li>Suites are versioned and curated.</li>
      <li>Budgets and seeds are explicit in the exported definitions.</li>
      <li>Gap-to-BKS is computed from the TSPLIB reference distance for the shipped instance.</li>
    </ul>
  </section>

  <section class="section-block" id="official-suites">
    <div class="section-heading">
      <p class="kicker">Official suites</p>
      <h2>Current suite definitions</h2>
      <p>The suite table is the source for the official Arena results section and the arena instance set.</p>
    </div>
    <SuitesTable />
  </section>

  <section class="section-block" id="current-solvers">
    <div class="section-heading">
      <p class="kicker">Current solver set</p>
      <h2>Published cards in this release</h2>
      <p>The catalog mixes a transparent greedy baseline, a built-in local-search baseline, and one external comparison point from OR-Tools.</p>
    </div>
    <div class="destination-grid">
      {solverRows.map((row) => (
        <article class="destination-card">
          <p class="kicker">{row.method_class} • {row.listing_tier}</p>
          <h3>{row.name}</h3>
          <p>{row.summary}</p>
          <div class="panel-meta">
            <span>Tested scale: {row.limits?.tested_max_nodes ?? "n/a"} nodes</span>
            <span>{Array.isArray(row.official_suite_ids) ? row.official_suite_ids.length : 0} official suite{Array.isArray(row.official_suite_ids) && row.official_suite_ids.length === 1 ? "" : "s"}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block section-panel" id="artifacts">
    <div class="section-heading">
      <p class="kicker">Generated artifacts</p>
      <h2>The public site is built from repo exports</h2>
    </div>
    <div class="panel-meta">
      <code>web/public/data/catalog.json</code>
      <code>web/public/data/leaderboards.json</code>
      <code>web/public/data/evals/*.json</code>
      <code>web/public/data/tsp_arena.json</code>
    </div>
  </section>
</BaseLayout>
