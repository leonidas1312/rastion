---
const base = import.meta.env.BASE_URL;
---
<header class="header">
  <div class="container header-inner">
    <a class="brand" href={`${base}`}>
      <img src={`${base}owl-favicon.png`} alt="Rastion owl" />
      <span>Rastion Routing Hub</span>
    </a>
    <nav class="nav">
      <a href={`${base}`}>Home</a>
      <a href={`${base}solvers/`}>Solvers</a>
      <a href={`${base}leaderboards/`}>Leaderboards</a>
      <a href={`${base}arena/`}>Arena</a>
      <a href={`${base}suites/`}>Suites</a>
      <a href={`${base}contribute/`}>Contribute</a>
      <button class="toggle-theme" type="button" aria-label="Toggle dark mode">Theme</button>
    </nav>
  </div>
</header>
