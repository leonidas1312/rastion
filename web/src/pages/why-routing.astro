---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Scope"
  description="This page has moved to the new About page."
  canonical="/about/"
  redirectTo="/about/#positioning"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#positioning`}
    description="The current v0.1 scope framing now lives on the consolidated About page."
    ctaLabel="Open About"
  />
</BaseLayout>
