---
import { existsSync, readFileSync } from "node:fs";

import PageIntro from "../components/PageIntro.astro";
import SuitesTable from "../components/SuitesTable.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const catalogPath = new URL("../../public/data/catalog.json", import.meta.url);
const leaderboardsPath = new URL("../../public/data/leaderboards.json", import.meta.url);

const catalog = existsSync(catalogPath) ? JSON.parse(readFileSync(catalogPath, "utf-8")) : { solvers: [] };
const leaderboards = existsSync(leaderboardsPath) ? JSON.parse(readFileSync(leaderboardsPath, "utf-8")) : { leaderboards: [] };

const solverRows = Array.isArray(catalog.solvers) ? catalog.solvers : [];
const suiteRows = Array.isArray(leaderboards.leaderboards) ? leaderboards.leaderboards : [];
const solverCount = solverRows.length;
const suiteCount = suiteRows.length;
---
<BaseLayout title="Rastion • About" description="Product philosophy, scope, and evaluation contract for Rastion's public TSP release." canonical="/about/">
  <PageIntro
    eyebrow="About"
    title="How Rastion thinks about public solver publishing"
    lede="Rastion is the evaluation and publishing layer for executable routing solvers. The public TSP release is intentionally narrow so every claim can stay inspectable."
  >
    <TrustNote slot="note" href="#evaluation" linkLabel="Jump to evaluation contract">
      The current release contains {solverCount} published solver cards and {suiteCount} generated result exports.
    </TrustNote>
  </PageIntro>

  <section class="section-block section-panel" id="philosophy">
    <div class="section-heading">
      <p class="kicker">Philosophy</p>
      <h2>Opinionated, inspectable, and narrow on purpose</h2>
      <p>Rastion does not try to be a neutral marketplace for every routing backend. The product value is the publication contract: executable adapters, public cards, generated evidence, and a replay surface that lets readers inspect the actual run.</p>
    </div>
  </section>

  <section class="section-block" id="scope">
    <div class="section-heading">
      <p class="kicker">Scope</p>
      <h2>What the current public release does and does not cover</h2>
    </div>
    <div class="vision-grid">
      <article class="destination-card">
        <h3>In bounds</h3>
        <ul class="list-reset">
          <li>TSP-first published adapters with executable cards.</li>
          <li>Generated suite exports stored in `web/public/data`.</li>
          <li>A replay-oriented Arena for TSPLIB route inspection.</li>
        </ul>
      </article>
      <article class="destination-card">
        <h3>Out of bounds</h3>
        <ul class="list-reset">
          <li>No global ranking across unrelated routing families.</li>
          <li>No public promise of CVRP or VRPTW breadth in v0.1.</li>
          <li>No ecosystem strip entries without a real published adapter behind them.</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section-block section-panel" id="public-surface">
    <div class="section-heading">
      <p class="kicker">Public surface</p>
      <h2>What readers can inspect today</h2>
    </div>
    <div class="destination-grid">
      <article class="destination-card">
        <h3>Solver cards</h3>
        <p>Executable adapter listings with install commands, limits, references, and suite coverage.</p>
      </article>
      <article class="destination-card">
        <h3>Arena replays</h3>
        <p>TSPLIB route geometry, progress traces, and BKS-relative evidence for exported runs.</p>
      </article>
      <article class="destination-card">
        <h3>Contributor flow</h3>
        <p>A repo-verified path for turning a local adapter into a public card and generated exports.</p>
      </article>
    </div>
  </section>

  <section class="section-block section-panel" id="evaluation">
    <div class="section-heading">
      <p class="kicker">Evaluation contract</p>
      <h2>Versioned suites with stored artifacts</h2>
      <p>Each public result export fixes its TSPLIB instance, budget policy, and seed policy. The generated JSON stores the per-instance rows, aggregate standings, and the artifact path that produced the output.</p>
    </div>
    <ul class="list-reset">
      <li>Suites are versioned and curated.</li>
      <li>Budgets and seeds are explicit in the exported definitions.</li>
      <li>Gap-to-BKS is computed from the TSPLIB reference distance for the shipped instance.</li>
      <li>`leaderboards.json` remains a compatibility filename, not a product promise of global leaderboard semantics.</li>
    </ul>
  </section>

  <section class="section-block" id="official-suites">
    <div class="section-heading">
      <p class="kicker">Published suites</p>
      <h2>Current suite definitions</h2>
      <p>The suite table defines the current publication contract and the instance set that powers the shipped TSPLIB evidence.</p>
    </div>
    <SuitesTable />
  </section>

  <section class="section-block" id="current-solvers">
    <div class="section-heading">
      <p class="kicker">Published adapters</p>
      <h2>Cards in the current release</h2>
      <p>The public catalog mixes transparent baselines with one external comparison point from OR-Tools. New integrations only belong here once they ship as real cards with generated evidence.</p>
    </div>
    <div class="destination-grid">
      {solverRows.map((row) => (
        <article class="destination-card">
          <p class="kicker">{row.method_class} • {row.listing_tier}</p>
          <h3>{row.name}</h3>
          <p>{row.summary}</p>
          <div class="panel-meta">
            <span>Tested scale: {row.limits?.tested_max_nodes ?? "n/a"} nodes</span>
            <span>{Array.isArray(row.official_suite_ids) ? row.official_suite_ids.length : 0} published suite{Array.isArray(row.official_suite_ids) && row.official_suite_ids.length === 1 ? "" : "s"}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block section-panel" id="artifacts">
    <div class="section-heading">
      <p class="kicker">Generated artifacts</p>
      <h2>The public site is built from repo exports</h2>
    </div>
    <div class="panel-meta">
      <code>web/public/data/catalog.json</code>
      <code>web/public/data/suites.json</code>
      <code>web/public/data/leaderboards.json</code>
      <code>web/public/data/evals/*.json</code>
      <code>web/public/data/tsp_arena.json</code>
    </div>
  </section>

  <section class="section-block section-panel" id="publication-rules">
    <div class="section-heading">
      <p class="kicker">Publication rules</p>
      <h2>What a new integration must satisfy</h2>
    </div>
    <ul class="list-reset">
      <li>A working adapter under `plugins_local/` or an equivalent supported plugin path.</li>
      <li>A public solver card and detail README with honest limits and failure modes.</li>
      <li>Generated suite output that can be rebuilt from the repo flow.</li>
      <li>A restrained public claim that matches the published evidence and current TSP scope.</li>
    </ul>
  </section>
</BaseLayout>
