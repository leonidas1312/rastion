---
import CatalogTable from "../components/CatalogTable.astro";
import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Rastion • Solver Catalog" description="Executable TSP solver cards with install details, limits, and published suite coverage." canonical="/solvers/" wide={true}>
  <PageIntro
    eyebrow="Solvers"
    title="Executable TSP solver cards"
    lede="Each card points to a real adapter in the repo and lists the install path, method, limits, references, and published suite coverage."
  >
    <TrustNote slot="note" href="../about/#evaluation" linkLabel="How coverage is generated">
      Coverage counts are taken from the current suite exports in `web/public/data`.
    </TrustNote>
  </PageIntro>

  <section class="section-block">
    <CatalogTable />
  </section>
</BaseLayout>
