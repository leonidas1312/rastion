---
import LeaderboardsTable from "../components/LeaderboardsTable.astro";
import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Rastion • Leaderboards" description="Official suite-scoped TSP leaderboards for the Rastion public TSP hub." canonical="/leaderboards/" wide={true}>
  <PageIntro
    eyebrow="Leaderboards"
    title="Official suite results"
    lede="Compare published TSP results from curated suites with fixed budgets, fixed seeds, and stored artifacts."
  >
    <TrustNote slot="note" href="../about/#evaluation" linkLabel="How evaluation works">
      Phase 1 results are suite-scoped. The current track is intentionally narrow and auditable.
    </TrustNote>
  </PageIntro>

  <section class="section-block">
    <LeaderboardsTable />
  </section>
</BaseLayout>
