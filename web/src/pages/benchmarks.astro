---
import BaseLayout from "../layouts/BaseLayout.astro";
import BenchmarkTable from "../components/BenchmarkTable.astro";
---
<BaseLayout title="Rastion • Benchmarks" description="Benchmark cache exported for website rendering.">
  <section class="card">
    <p class="kicker">Benchmark Cache</p>
    <h1>Benchmarks</h1>
    <p>
      Rows are normalized from <code>.rastion/benchmarks.json</code> using
      <code>python -m rastion export-benchmarks</code>.
    </p>
  </section>
  <div class="grid" style="margin-top: 1rem;">
    <BenchmarkTable />
  </div>
</BaseLayout>
