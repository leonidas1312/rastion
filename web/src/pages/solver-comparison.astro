---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Solver Comparison"
  description="This page has moved to the new About page."
  canonical="/about/"
  redirectTo="/about/#current-solvers"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#current-solvers`}
    description="Current solver roles now live on the consolidated About page."
    ctaLabel="Open About"
  />
</BaseLayout>
