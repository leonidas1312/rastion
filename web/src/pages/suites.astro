---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Suites"
  description="This page has moved to the new About page."
  canonical="/about/"
  redirectTo="/about/#official-suites"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#official-suites`}
    description="Official suite definitions now live on the consolidated About page."
    ctaLabel="Open About"
  />
</BaseLayout>
