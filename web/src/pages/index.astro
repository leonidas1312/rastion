---
import { existsSync, readFileSync } from "node:fs";

import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

function readJson(path, fallback) {
  return existsSync(path) ? JSON.parse(readFileSync(path, "utf-8")) : fallback;
}

const catalog = readJson(new URL("../../public/data/catalog.json", import.meta.url), { solvers: [], generated_at: null });
const leaderboards = readJson(new URL("../../public/data/leaderboards.json", import.meta.url), { leaderboards: [], generated_at: null });
const suites = readJson(new URL("../../public/data/suites.json", import.meta.url), { suites: [], generated_at: null });
const arena = readJson(new URL("../../public/data/tsp_arena.json", import.meta.url), { instances: [], generated_at: null });

const solverCount = Array.isArray(catalog.solvers) ? catalog.solvers.length : 0;
const leaderboardCount = Array.isArray(leaderboards.leaderboards) ? leaderboards.leaderboards.length : 0;
const suiteCount = Array.isArray(suites.suites) ? suites.suites.length : leaderboardCount;
const arenaCount = Array.isArray(arena.instances) ? arena.instances.length : 0;
const latest = [catalog.generated_at, leaderboards.generated_at, suites.generated_at, arena.generated_at]
  .filter((value) => typeof value === "string" && value.length > 0)
  .sort()
  .reverse()[0];
const latestLabel = latest ? new Date(latest).toLocaleString() : "Awaiting export";
---
<BaseLayout title="Rastion • Public TSP Hub" description="Rastion publishes executable TSP solver cards, TSPLIB suite results, and replayable arena exports." canonical="/" >
  <PageIntro
    eyebrow="Public TSP hub"
    title="Browse TSP solvers, results, and TSPLIB replays."
    lede="Rastion keeps the public TSP release focused on two surfaces: executable solver cards and an Arena page that combines replayable TSPLIB runs with official suite results."
    split={true}
  >
    <div slot="actions" class="intro-actions">
      <a class="button-primary" href={`${base}arena/`}>Open the Arena</a>
      <a class="button-secondary" href={`${base}solvers/`}>Browse Solvers</a>
      <a class="text-link" href={`${base}about/#evaluation`}>How results work</a>
    </div>
    <div slot="note" class="note-cluster">
      <TrustNote href={`${base}about/`} linkLabel="Method and scope">
        v0.1 covers TSP only and publishes three TSPLIB suite exports with matching arena data.
      </TrustNote>
      <p class="trust-note">Works with Google OR-Tools via the published solver adapter track.</p>
    </div>
    <aside slot="aside" class="proof-panel">
      <p class="kicker">Current export</p>
      <div class="proof-grid">
        <div class="proof-item">
          <strong>{solverCount}</strong>
          <span>executable solver{solverCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{suiteCount}</strong>
          <span>official suite{suiteCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{arenaCount}</strong>
          <span>arena instance{arenaCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{leaderboardCount}</strong>
          <span>official result set{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
      </div>
      <p class="proof-meta">Latest export: {latestLabel}</p>
    </aside>
  </PageIntro>

  <section class="section-block">
    <div class="section-heading">
      <p class="kicker">Explore</p>
      <h2>Two ways to inspect the same dataset</h2>
      <p>Use Arena to replay exported runs and inspect official suite outputs, or open the solver catalog to inspect implementation details.</p>
    </div>
    <div class="destination-grid">
      <article class="destination-card">
        <p class="kicker">Arena</p>
        <h3>Replay runs and read official results</h3>
        <p>See the full tour, the recorded best-distance-over-time trace, and the official suite standings on the same page.</p>
        <div class="panel-meta">
          <span>{arenaCount} exported instance{arenaCount === 1 ? "" : "s"}</span>
          <span>{leaderboardCount} official result set{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}arena/`}>Open the arena</a>
      </article>
      <article class="destination-card">
        <p class="kicker">Solvers</p>
        <h3>Inspect the solver cards</h3>
        <p>Check method, tested scale, install path, references, and current suite coverage for each published solver.</p>
        <div class="panel-meta">
          <span>{solverCount} solver card{solverCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}solvers/`}>Browse the catalog</a>
      </article>
    </div>
  </section>

  <section class="section-block">
    <article class="section-panel">
      <div class="section-heading">
        <p class="kicker">What is included</p>
        <h2>The current public surface is small and specific</h2>
        <p>The site ships three TSPLIB instances, three published solver cards, and the generated JSON artifacts behind the tables and arena views. Each page is reading the same exported data that local contributors regenerate in the repo.</p>
      </div>
      <div class="panel-meta">
        <span>Catalog export</span>
        <code>web/public/data/catalog.json</code>
        <span>Official results export</span>
        <code>web/public/data/leaderboards.json</code>
        <span>Arena export</span>
        <code>web/public/data/tsp_arena.json</code>
      </div>
      <div class="intro-actions">
        <a class="button-secondary" href={`${base}contribute/`}>Open the contributor guide</a>
      </div>
    </article>
  </section>
</BaseLayout>
