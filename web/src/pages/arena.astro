---
import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Rastion • TSP Arena" description="Replay TSPLIB tours, compare them with best-known distances, and inspect exported solver traces." canonical="/arena/" wide={true}>
  <PageIntro
    eyebrow="Arena"
    title="TSP Arena"
    lede="Arena is the replay surface for Rastion's public TSP release. Inspect one exported TSPLIB run at a time, compare it with the best-known distance, and read the recorded optimization trace behind the route."
  >
    <TrustNote slot="note" href="../about/#evaluation" linkLabel="Official eval context">
      Best-known distances come from the TSPLIB reference. Arena replays use the same generated exports that back the published solver cards.
    </TrustNote>
  </PageIntro>

  <div class="grid grid-main-aside section-block">
    <section class="card">
      <div class="controls">
        <label for="instance-select">Problem size:</label>
        <select id="instance-select" aria-label="Choose TSPLIB instance"></select>

        <label for="solver-focus">Route focus:</label>
        <select id="solver-focus" aria-label="Focus solver">
          <option value="__all__">Overlay all solvers</option>
        </select>

        <span class="status" id="arena-meta">Loading TSPLIB arena...</span>
      </div>

      <div class="grid grid-two arena-summary">
        <article class="section-panel">
          <p class="kicker">Selected solver</p>
          <h3 id="arena-selected-solver">Awaiting data</h3>
          <p class="subtle" id="arena-selected-summary">The default view picks the best successful solver for the current instance.</p>
        </article>
        <article class="section-panel">
          <p class="kicker">Reference</p>
          <h3 id="arena-reference-distance">Awaiting data</h3>
          <p class="subtle" id="arena-reference-summary">Best-known distance is shown when the instance is covered by the TSPLIB reference set.</p>
        </article>
      </div>

      <h2>Instance Map</h2>
      <p class="subtle">Full closed tour over TSPLIB coordinates. The depot/start node is marked in red.</p>
      <canvas class="map" id="tsp-map" width="960" height="420"></canvas>
    </section>

    <section class="card">
      <h2>Solver Runs</h2>
      <p class="subtle">These rows cover the currently selected exported TSPLIB run only. Use them as per-instance evidence, not as a global ranking.</p>
      <p class="status" id="arena-status">Loading solver runs...</p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Solver</th>
              <th>Best Distance</th>
              <th>Gap to BKS</th>
              <th>Runtime (ms)</th>
              <th>Events</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="arena-runs-body">
            <tr><td colspan="6">Waiting for data...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card">
      <h2>Progress Plot</h2>
      <p class="subtle">Best full-tour distance over elapsed time. The dashed guide marks the TSPLIB best-known distance when available.</p>
      <canvas class="chart" id="arena-chart" width="960" height="340"></canvas>
    </section>
  </div>

  <script>
    import { renderArenaChart } from "../components/ArenaChart";
    import { renderTspMap } from "../components/TspMap";
    import { fetchJson, formatIso } from "../components/dataLoader";

    const instanceSelect = document.querySelector("#instance-select");
    const solverFocus = document.querySelector("#solver-focus");
    const meta = document.querySelector("#arena-meta");
    const status = document.querySelector("#arena-status");
    const body = document.querySelector("#arena-runs-body");
    const chartCanvas = document.querySelector("#arena-chart");
    const mapCanvas = document.querySelector("#tsp-map");
    const selectedSolver = document.querySelector("#arena-selected-solver");
    const selectedSummary = document.querySelector("#arena-selected-summary");
    const referenceDistance = document.querySelector("#arena-reference-distance");
    const referenceSummary = document.querySelector("#arena-reference-summary");

    let bundle = null;
    let activeInstanceId = null;
    const OVERLAY_ALL = "__all__";

    function formatSize(instance) {
      const label = String(instance.size || "custom").toLowerCase();
      return `${label} • ${instance.name} (n=${instance.n_vars})`;
    }

    function formatDistance(value) {
      return value === null || value === undefined ? "n/a" : Number(value).toFixed(2);
    }

    function formatGap(value) {
      return value === null || value === undefined ? "n/a" : `${Number(value).toFixed(2)}%`;
    }

    function bestSuccessfulRow(rows) {
      return rows.find((row) => !row.error) || null;
    }

    function rowHtml(row) {
      const hasError = typeof row.error === "string" && row.error.length > 0;
      const statusText = hasError ? "error" : "ok";
      const distance = hasError ? "n/a" : formatDistance(row.final?.best_value);
      const gap = hasError ? "n/a" : formatGap(row.gap_to_reference_pct);
      const runtime = hasError ? "-" : Number(row.final?.runtime_ms ?? 0);
      const events = Array.isArray(row.events) ? row.events.length : 0;

      return `<tr>
        <td><strong>${row.name}</strong></td>
        <td>${distance}</td>
        <td>${gap}</td>
        <td>${runtime}</td>
        <td>${events}</td>
        <td>${statusText}</td>
      </tr>`;
    }

    function activeInstance() {
      const id = instanceSelect.value;
      const instances = Array.isArray(bundle?.instances) ? bundle.instances : [];
      return instances.find((instance) => instance.id === id) || instances[0] || null;
    }

    function renderInstance() {
      const instance = activeInstance();
      if (!instance) {
        body.innerHTML = '<tr><td colspan="6">No TSPLIB instances available.</td></tr>';
        status.textContent = "No arena data available.";
        meta.textContent = "Run: rastion build-site-data";
        selectedSolver.textContent = "No solver selected";
        selectedSummary.textContent = "No arena data available.";
        referenceDistance.textContent = "No reference";
        referenceSummary.textContent = "No TSPLIB reference data available.";
        return;
      }

      const allRows = Array.isArray(instance.solvers) ? [...instance.solvers] : [];
      allRows.sort(
        (a, b) =>
          Number(a.final?.best_value ?? Number.POSITIVE_INFINITY) -
            Number(b.final?.best_value ?? Number.POSITIVE_INFINITY) ||
          Number(a.final?.runtime_ms ?? Number.POSITIVE_INFINITY) -
            Number(b.final?.runtime_ms ?? Number.POSITIVE_INFINITY),
      );
      const bestRow = bestSuccessfulRow(allRows);

      body.innerHTML = allRows.map(rowHtml).join("\n");
      status.textContent = `Replay export updated: ${formatIso(bundle.generated_at)} • Instance: ${instance.name}`;
      meta.textContent = `${instance.source || "tsplib"} • depot=${instance.depot} • nodes=${instance.n_vars}${instance.reference ? ` • ${instance.reference.label}: ${formatDistance(instance.reference.distance)}` : ""}`;

      const focusBefore = solverFocus.value;
      const options = [`<option value="${OVERLAY_ALL}">Overlay all solvers</option>`]
        .concat(allRows.map((row) => `<option value="${row.name}">${row.name}</option>`))
        .join("\n");
      solverFocus.innerHTML = options;
      if (instance.id !== activeInstanceId) {
        solverFocus.value = bestRow?.name || OVERLAY_ALL;
        activeInstanceId = instance.id;
      } else if (allRows.some((row) => row.name === focusBefore) || focusBefore === OVERLAY_ALL) {
        solverFocus.value = focusBefore;
      } else {
        solverFocus.value = bestRow?.name || OVERLAY_ALL;
      }

      const focused = solverFocus.value === OVERLAY_ALL ? null : solverFocus.value || null;
      const selectedRow = focused ? allRows.find((row) => row.name === focused) || bestRow : bestRow;

      selectedSolver.textContent = solverFocus.value === OVERLAY_ALL ? "Overlay all solvers" : focused || bestRow?.name || "No solver";
      if (selectedRow?.error) {
        selectedSummary.textContent = selectedRow.error;
      } else if (selectedRow) {
        selectedSummary.textContent = `Best distance ${formatDistance(selectedRow.final?.best_value)} • gap ${formatGap(selectedRow.gap_to_reference_pct)} • runtime ${Number(selectedRow.final?.runtime_ms ?? 0)} ms`;
      } else {
        selectedSummary.textContent = "No successful exported run for this instance.";
      }

      if (instance.reference) {
        referenceDistance.textContent = `${instance.reference.label}: ${formatDistance(instance.reference.distance)}`;
        referenceSummary.innerHTML = instance.reference.url
          ? `Reference value used for gap-to-BKS. <a href="${instance.reference.url}">Source</a>`
          : "Reference value used for gap-to-BKS.";
      } else {
        referenceDistance.textContent = "No reference";
        referenceSummary.textContent = "No TSPLIB reference data available for this instance.";
      }

      const series = allRows
        .filter((row) => !row.error)
        .map((row) => ({
          name: row.name,
          events: Array.isArray(row.events) ? row.events : [],
        }));

      const routes = allRows
        .filter((row) => !row.error)
        .map((row) => ({
          name: row.name,
          route: Array.isArray(row.final?.route) ? row.final.route : [],
        }));

      renderArenaChart(chartCanvas, series, focused, instance.reference || null);
      renderTspMap(mapCanvas, Array.isArray(instance.nodes) ? instance.nodes : [], Number(instance.depot ?? 0), routes, focused);
    }

    async function load() {
      try {
        bundle = await fetchJson("data/tsp_arena.json");
        const instances = Array.isArray(bundle.instances) ? bundle.instances : [];
        if (!instances.length) {
          body.innerHTML = '<tr><td colspan="6">No TSPLIB instances found.</td></tr>';
          status.textContent = "No TSPLIB arena data available.";
          meta.textContent = "Run: rastion build-site-data";
          return;
        }

        instanceSelect.innerHTML = instances
          .map((instance) => `<option value="${instance.id}">${formatSize(instance)}</option>`)
          .join("\n");

        renderInstance();

        instanceSelect.addEventListener("change", renderInstance);
        solverFocus.addEventListener("change", renderInstance);
        window.addEventListener("resize", renderInstance);
      } catch (error) {
        body.innerHTML = '<tr><td colspan="6">No data found.</td></tr>';
        status.classList.add("error");
        status.textContent = "Missing /data/tsp_arena.json. Run: rastion build-site-data";
        meta.textContent = "TSPLIB arena unavailable.";
        console.error(error);
      }
    }

    load();
  </script>
</BaseLayout>
