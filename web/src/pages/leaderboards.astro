---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Official Results"
  description="Official TSP suite results now live inside the Arena page."
  canonical="/arena/"
  redirectTo="/arena/#official-results"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}arena/#official-results`}
    title="Official results moved into Arena"
    description="The standalone Leaderboards page has been folded into Arena. Official suite results now live below the replay and trace views."
    ctaLabel="Open Arena results"
  />
</BaseLayout>
