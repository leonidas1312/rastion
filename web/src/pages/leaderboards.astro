---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeaderboardsTable from "../components/LeaderboardsTable.astro";
---
<BaseLayout title="Rastion • Leaderboards" description="Official suite-scoped TSP leaderboards for the routing-first hub.">
  <section class="card">
    <p class="kicker">Official Evals</p>
    <h1>Leaderboards</h1>
    <p>
      Rankings are suite-scoped, TSP-only, and generated from curated TSPLIB instances with fixed budgets and seeds.
      The current published track is a bootstrap track: official within Rastion, intentionally narrow, and explicit
      about what the current suite corpus does and does not prove. Phase 1 does not publish a fake "best routing
      solver" global ranking.
    </p>
    <p><a href="../methodology/">Read the methodology and caveats</a></p>
  </section>
  <div class="grid" style="margin-top: 1rem;">
    <LeaderboardsTable />
  </div>
</BaseLayout>
