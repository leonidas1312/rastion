---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Benchmarks"
  description="This page has moved to the public evaluation surfaces."
  canonical="/arena/"
  redirectTo="/arena/#official-results"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}arena/#official-results`}
    description="Raw benchmark-cache exports remain developer-only. Public official results now live inside Arena."
    ctaLabel="Open Arena results"
  />
</BaseLayout>
