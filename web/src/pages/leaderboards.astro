---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Evaluation Contract"
  description="Public evaluation details now live in the About page and solver cards."
  canonical="/about/"
  redirectTo="/about/#evaluation"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#evaluation`}
    title="Standalone leaderboards were retired"
    description="Rastion now treats evaluation as a publication contract, not a standalone leaderboard surface. Read the contract on the About page or inspect coverage on each solver card."
    ctaLabel="Open evaluation details"
  />
</BaseLayout>
