---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Methodology"
  description="This page has moved to the new About page."
  canonical="/about/"
  redirectTo="/about/#evaluation"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#evaluation`}
    description="Evaluation framing now lives on the consolidated About page."
    ctaLabel="Open About"
  />
</BaseLayout>
