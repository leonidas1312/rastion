---
import { existsSync, readFileSync } from "node:fs";

const suitesPath = new URL("../../public/data/suites.json", import.meta.url);

const payload = existsSync(suitesPath) ? JSON.parse(readFileSync(suitesPath, "utf-8")) : null;
const rows = Array.isArray(payload?.suites) ? payload.suites : [];
const updated = payload?.generated_at ? new Date(payload.generated_at).toLocaleString() : null;
---
<section class="section-panel">
  <p class="status">
    {updated ? `Last updated: ${updated} • ${rows.length} official suite definition${rows.length === 1 ? "" : "s"}` : "No suite export found. Run `rastion build-site-data`."}
  </p>
  <div class="table-panel">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Suite</th>
            <th>Track</th>
            <th>Variant</th>
            <th>Instances</th>
            <th>Budget</th>
            <th>Seeds</th>
            <th>Schema</th>
          </tr>
        </thead>
        <tbody>
          {rows.length ? (
            rows.map((row) => {
              const instances = Array.isArray(row.instances)
                ? row.instances.map((instance) => `${instance.label} (${instance.size})`).join(", ")
                : "n/a";
              const track = Array.isArray(row.instances) && row.instances.length <= 1 ? "bootstrap v0" : "expanded";
              const seeds = Array.isArray(row.seed_policy?.seeds) ? row.seed_policy.seeds.join(", ") : "n/a";
              return (
                <tr>
                  <td><strong>{row.title}</strong><br /><span class="subtle">{row.id}</span></td>
                  <td><span class="badge">{track}</span></td>
                  <td>{row.problem_variant}</td>
                  <td>{instances}</td>
                  <td>{row.budget_policy?.iters ?? "n/a"} iters / {row.budget_policy?.time_budget_ms ?? "n/a"} ms</td>
                  <td>{seeds}</td>
                  <td>{row.result_schema_version}</td>
                </tr>
              );
            })
          ) : (
            <tr>
              <td colspan="7">No suite specs exported yet.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</section>
