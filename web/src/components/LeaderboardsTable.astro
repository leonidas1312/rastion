---
import { existsSync, readFileSync } from "node:fs";

const base = import.meta.env.BASE_URL;
const leaderboardsPath = new URL("../../public/data/leaderboards.json", import.meta.url);

const payload = existsSync(leaderboardsPath) ? JSON.parse(readFileSync(leaderboardsPath, "utf-8")) : null;
const suites = Array.isArray(payload?.leaderboards) ? payload.leaderboards : [];
const updated = payload?.generated_at ? new Date(payload.generated_at).toLocaleString() : null;
---
<section class="section-panel stack-lg">
  <p class="status">
    {updated ? `Last updated: ${updated} • ${suites.length} official suite result set${suites.length === 1 ? "" : "s"}` : "No official results export found. Run `rastion build-site-data`."}
  </p>
  {
    suites.length ? (
      suites.map((suitePayload) => {
        const suite = suitePayload.suite || {};
        const standings = Array.isArray(suitePayload.standings) ? suitePayload.standings : [];
        const instances = Array.isArray(suitePayload.instances) ? suitePayload.instances : [];
        const instanceLabels = instances.length
          ? instances.map((instance) => `${instance.label} (${instance.size})`).join(", ")
          : "n/a";
        const reference = instances.length === 1 ? instances[0].reference || null : null;
        const track = Array.isArray(suitePayload.instances) && suitePayload.instances.length <= 1 ? "bootstrap v0" : "expanded";
        const seeds = Array.isArray(suite.seed_policy?.seeds) ? suite.seed_policy.seeds.join(", ") : "n/a";

        return (
          <article class="suite-card">
            <div class="metric-strip">
              <div>
                <p class="kicker">Suite</p>
                <h3>{suite.title || "Unknown suite"}</h3>
              </div>
              <span class="badge">{track}</span>
            </div>
            <p>{suite.description || "No suite description found."}</p>
            <div class="panel-meta">
              <span>{suite.problem_variant || "n/a"}</span>
              <span>{instanceLabels}</span>
              <span>{suite.budget_policy?.iters ?? "n/a"} iters / {suite.budget_policy?.time_budget_ms ?? "n/a"} ms</span>
              <span>Seeds: {seeds}</span>
              {reference && <span>{reference.label}: {Number(reference.distance).toFixed(2)}</span>}
            </div>
            <div class="table-panel">
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Solver</th>
                      <th>Method</th>
                      <th>Mean Distance</th>
                      <th>Gap to BKS</th>
                      <th>Mean Runtime (ms)</th>
                      <th>Coverage</th>
                    </tr>
                  </thead>
                  <tbody>
                    {standings.length ? (
                      standings.map((row) => (
                        <tr>
                          <td><a href={`${base}solvers/${row.solver_slug}/`}><strong>{row.solver_name}</strong></a><br /><span class="subtle">{row.listing_tier}</span></td>
                          <td>{row.method_class}</td>
                          <td>{row.mean_score === null ? "n/a" : Number(row.mean_score).toFixed(2)}</td>
                          <td>{row.mean_gap_to_reference_pct === null ? "n/a" : `${Number(row.mean_gap_to_reference_pct).toFixed(2)}%`}</td>
                          <td>{row.mean_runtime_ms === null ? "n/a" : Number(row.mean_runtime_ms).toFixed(2)}</td>
                          <td>{row.completed_instances}/{row.total_instances}</td>
                        </tr>
                      ))
                    ) : (
                      <tr>
                        <td colspan="6">No results found.</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </div>
            <div class="panel-meta">
              <span>Artifact</span>
              <code>{suitePayload.artifact_path}</code>
              {reference?.url && <a href={reference.url}>Reference source</a>}
            </div>
          </article>
        );
      })
    ) : (
      <div class="card">No leaderboards exported yet.</div>
    )
  }
</section>
