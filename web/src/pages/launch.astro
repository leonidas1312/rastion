---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Launch"
  description="This page has moved to the new About page."
  canonical="/about/"
  redirectTo="/about/#phase-1"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#phase-1`}
    description="The v0.1 launch framing now lives on the consolidated About page."
    ctaLabel="Open About"
  />
</BaseLayout>
