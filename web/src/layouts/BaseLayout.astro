---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  redirectTo?: string;
  noIndex?: boolean;
  wide?: boolean;
}

const {
  title,
  description = "Rastion is the evaluation and publishing layer for executable routing solvers, with public TSP cards, generated result exports, and replayable arena evidence.",
  canonical,
  redirectTo,
  noIndex = false,
  wide = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalHref = canonical ? `${base}${String(canonical).replace(/^\/+/, "")}` : null;
const redirectHref = redirectTo ? `${base}${String(redirectTo).replace(/^\/+/, "")}` : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}owl-favicon.png`} />
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    {noIndex && <meta name="robots" content="noindex,follow" />}
    {redirectHref && <meta http-equiv="refresh" content={`0;url=${redirectHref}`} />}
  </head>
  <body data-base={base}>
    <div class="site-shell">
      <Header />
      <main class:list={["container", wide && "container-wide", "fade-in"]}>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      window.__RASTION_BASE__ = document.body.dataset.base || "/";

      const root = document.documentElement;
      const key = "rastion-theme";
      const preferred = localStorage.getItem(key);
      if (preferred === "dark") {
        root.classList.add("dark");
      }

      document.querySelectorAll(".toggle-theme").forEach((button) => {
        button.addEventListener("click", () => {
          root.classList.toggle("dark");
          localStorage.setItem(key, root.classList.contains("dark") ? "dark" : "light");
        });
      });
    </script>
  </body>
</html>
