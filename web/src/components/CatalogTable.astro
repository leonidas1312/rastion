---
import { existsSync, readFileSync } from "node:fs";

const base = import.meta.env.BASE_URL;
const catalogPath = new URL("../../public/data/catalog.json", import.meta.url);

const payload = existsSync(catalogPath) ? JSON.parse(readFileSync(catalogPath, "utf-8")) : null;
const rows = Array.isArray(payload?.solvers) ? payload.solvers : [];
const updated = payload?.generated_at ? new Date(payload.generated_at).toLocaleString() : null;
---
<section class="section-panel">
  <p class="status">
    {updated ? `Last updated: ${updated} • ${rows.length} published solver card${rows.length === 1 ? "" : "s"}` : "No catalog export found. Run `rastion build-site-data`."}
  </p>
  <div class="table-panel">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Variant</th>
            <th>Method</th>
            <th>Hardware</th>
            <th>Tested Scale</th>
            <th>Eval Coverage</th>
            <th>License</th>
            <th>Tags</th>
          </tr>
        </thead>
        <tbody>
          {rows.length ? (
            rows.map((row) => {
              const detailHref = `${base}${String(row.detail_path || "").replace(/^\/+/, "")}`;
              const coverage = Array.isArray(row.official_suite_ids) ? row.official_suite_ids.length : 0;
              const tags = Array.isArray(row.tags) ? row.tags.join(", ") : "";
              return (
                <tr>
                  <td><a href={detailHref}><strong>{row.name}</strong></a><br /><span class="subtle">{row.listing_tier}</span></td>
                  <td>{(row.problem_variants || []).join(", ")}</td>
                  <td>{row.method_class}</td>
                  <td>{(row.hardware || []).join(", ") || "n/a"}</td>
                  <td>{row.limits?.tested_max_nodes ?? "n/a"} nodes</td>
                  <td>{coverage} suite{coverage === 1 ? "" : "s"}</td>
                  <td>{row.license}</td>
                  <td>{tags || "n/a"}</td>
                </tr>
              );
            })
          ) : (
            <tr>
              <td colspan="8">No solver cards exported yet.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</section>
