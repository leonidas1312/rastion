---
import CatalogTable from "../components/CatalogTable.astro";
import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Rastion • Solver Catalog" description="Executable TSP solver cards for the Rastion public TSP hub." canonical="/solvers/" wide={true}>
  <PageIntro
    eyebrow="Solvers"
    title="Executable solver cards"
    lede="Browse the current Phase 1 catalog by method, tested scale, evaluation coverage, and solver detail page."
  >
    <TrustNote slot="note" href="../about/#phase-1" linkLabel="What Phase 1 includes">
      Executable TSP solvers in Phase 1.
    </TrustNote>
  </PageIntro>

  <section class="section-block">
    <CatalogTable />
  </section>
</BaseLayout>
