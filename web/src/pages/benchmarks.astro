---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Benchmarks"
  description="This page has moved to the public evaluation surfaces."
  canonical="/about/"
  redirectTo="/about/#evaluation"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}about/#evaluation`}
    description="Raw benchmark-cache exports remain developer-only. Public evaluation framing now lives in the About page and published solver cards."
    ctaLabel="Open evaluation details"
  />
</BaseLayout>
