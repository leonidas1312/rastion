---
import { existsSync, readFileSync } from "node:fs";

import PageIntro from "../components/PageIntro.astro";
import TrustNote from "../components/TrustNote.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

function readJson(path, fallback) {
  return existsSync(path) ? JSON.parse(readFileSync(path, "utf-8")) : fallback;
}

const catalog = readJson(new URL("../../public/data/catalog.json", import.meta.url), { solvers: [], generated_at: null });
const leaderboards = readJson(new URL("../../public/data/leaderboards.json", import.meta.url), { leaderboards: [], generated_at: null });
const suites = readJson(new URL("../../public/data/suites.json", import.meta.url), { suites: [], generated_at: null });
const arena = readJson(new URL("../../public/data/tsp_arena.json", import.meta.url), { instances: [], generated_at: null });

const solverCount = Array.isArray(catalog.solvers) ? catalog.solvers.length : 0;
const leaderboardCount = Array.isArray(leaderboards.leaderboards) ? leaderboards.leaderboards.length : 0;
const suiteCount = Array.isArray(suites.suites) ? suites.suites.length : leaderboardCount;
const arenaCount = Array.isArray(arena.instances) ? arena.instances.length : 0;
const latest = [catalog.generated_at, leaderboards.generated_at, suites.generated_at, arena.generated_at]
  .filter((value) => typeof value === "string" && value.length > 0)
  .sort()
  .reverse()[0];
const latestLabel = latest ? new Date(latest).toLocaleString() : "Awaiting export";
---
<BaseLayout title="Rastion • Public TSP Hub" description="Rastion is a public hub for TSP solvers, with solver cards, reproducible evals, and replayable TSPLIB demos." canonical="/" >
  <PageIntro
    eyebrow="Public TSP hub"
    title="A public hub for TSP solvers."
    lede="Rastion is a public hub for TSP solvers, with solver cards, reproducible evals, and replayable TSPLIB demos."
    split={true}
  >
    <div slot="actions" class="intro-actions">
      <a class="button-primary" href={`${base}arena/`}>Open the Arena</a>
      <a class="button-secondary" href={`${base}solvers/`}>Browse Solvers</a>
      <a class="text-link" href={`${base}about/#evaluation`}>How results work</a>
    </div>
    <TrustNote slot="note" href={`${base}about/`} linkLabel="See the current scope">
      v0.1 is TSP-only. Results stay suite-scoped. The current track is intentionally small and auditable.
    </TrustNote>
    <aside slot="aside" class="proof-panel">
      <p class="kicker">Live proof</p>
      <div class="proof-grid">
        <div class="proof-item">
          <strong>{solverCount}</strong>
          <span>executable solver{solverCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{suiteCount}</strong>
          <span>official suite{suiteCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{arenaCount}</strong>
          <span>arena instance{arenaCount === 1 ? "" : "s"}</span>
        </div>
        <div class="proof-item">
          <strong>{leaderboardCount}</strong>
          <span>published leaderboard{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
      </div>
      <p class="proof-meta">Latest export: {latestLabel}</p>
    </aside>
  </PageIntro>

  <section class="section-block">
    <div class="section-heading">
      <p class="kicker">Explore</p>
      <h2>Three ways into Rastion</h2>
      <p>Start with the product surface that matches what you want to inspect right now.</p>
    </div>
    <div class="destination-grid">
      <article class="destination-card">
        <p class="kicker">Arena</p>
        <h3>Replay routes and progress</h3>
        <p>Compare TSPLIB instances, route geometry, and best-value-over-time traces in one place.</p>
        <div class="panel-meta">
          <span>{arenaCount} exported instance{arenaCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}arena/`}>Open the arena</a>
      </article>
      <article class="destination-card">
        <p class="kicker">Solvers</p>
        <h3>Inspect executable cards</h3>
        <p>See method class, tested scale, installation details, and solver-specific notes without leaving the catalog.</p>
        <div class="panel-meta">
          <span>{solverCount} solver card{solverCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}solvers/`}>Browse the catalog</a>
      </article>
      <article class="destination-card">
        <p class="kicker">Leaderboards</p>
        <h3>Read official suite results</h3>
        <p>Compare reproducible suite results with fixed budgets, fixed seeds, and artifact-backed output.</p>
        <div class="panel-meta">
          <span>{leaderboardCount} published suite result{leaderboardCount === 1 ? "" : "s"}</span>
        </div>
        <a href={`${base}leaderboards/`}>View leaderboards</a>
      </article>
    </div>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="kicker">What Rastion is</p>
      <h2>A narrow public release with a real end-to-end loop</h2>
      <p>Rastion packages one concrete workflow: publish TSP solver cards, run reproducible TSPLIB suites, and replay exported runs in the arena. The scope is deliberately small so outside readers can see what the project actually proves.</p>
      <TrustNote href={`${base}about/`} linkLabel="Read the full product framing">
        v0.1 is TSP-only. Results stay suite-scoped. Future work can expand only after the current surface earns it.
      </TrustNote>
    </div>
  </section>

  <section class="section-block">
    <article class="section-panel">
      <div class="section-heading">
        <p class="kicker">Why now</p>
        <h2>Publish a small thing people can judge honestly</h2>
        <p>Rastion is ready for a public v0.1 because the core loop is already real: executable cards, artifact-backed suite results, and replayable TSPLIB demos. The point of publishing now is to see whether people care enough to justify the next phase.</p>
      </div>
      <div class="intro-actions">
        <a class="button-secondary" href={`${base}contribute/`}>Open the contributor guide</a>
      </div>
    </article>
  </section>
</BaseLayout>
