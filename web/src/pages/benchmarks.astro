---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Benchmarks"
  description="This page has moved to the public evaluation surfaces."
  canonical="/leaderboards/"
  redirectTo="/leaderboards/"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}leaderboards/`}
    description="Raw benchmark-cache exports are developer-only. The public evaluation surface now lives on the Leaderboards page."
    ctaLabel="Open Leaderboards"
  />
</BaseLayout>
