---
import RedirectNotice from "../components/RedirectNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Rastion • Add a TSP Solver"
  description="This page has moved to the contributor guide."
  canonical="/contribute/"
  redirectTo="/contribute/"
  noIndex={true}
>
  <RedirectNotice
    target={`${base}contribute/`}
    description="The repo-verified contributor walkthrough now lives on the unified Contribute page."
    ctaLabel="Open Contribute"
  />
</BaseLayout>
